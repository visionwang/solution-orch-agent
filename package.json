{
  "name": "solution-orch-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.32.1",
    "concurrently": "^9.2.1",
    "docx": "^9.5.1",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.1",
    "vite": "^7.1.12",
    "vue": "^3.5.22",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "jsdom": "^27.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
